model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Auth

	annotation PBI_QueryGroupOrder = 0

queryGroup Load

	annotation PBI_QueryGroupOrder = 1

annotation PBI_QueryOrder = ["StartDate","dim_refresh_date","Measure","EndDate","RangeStart","RangeEnd","Web_app_url_factactivity","Web_app_url_dimproject","web_app_url_dimtask","Web_app_url_dimteam","Web_app_url_dimusers","Web_app_url_holiday","Web_app_url_metrics","Auth_Token","dim_date","fact_ActivityLog","dim_project","dim_task","dim_team","dim_users","Holiday","dim_metrics"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation __TEdtr = 1

annotation PBI_ProTooling = ["DevMode","DaxQueryView_Desktop"]

ref table dim_refresh_date
ref table Measure
ref table EndDate
ref table dim_date
ref table '# Hours'
ref table '# Month/Week'
ref table '# F Items'
ref table '# F Pages'
ref table '# Project'
ref table '# Project Axis Parameter'
ref table '# Payment / Teams'
ref table '# Param'
ref table dim_project
ref table fact_ActivityLog
ref table dim_team
ref table dim_task
ref table dim_users
ref table Holiday
ref table dim_metrics

ref cultureInfo en-US

