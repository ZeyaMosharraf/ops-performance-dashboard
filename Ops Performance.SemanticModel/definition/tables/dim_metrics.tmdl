	partition dim_metrics = m
		mode: import
		queryGroup: Load
		source =
				let
				
				    WebconnectorLink = Web_app_url_metrics,
				    connectorkey     = Auth_Token,
				
				    Source = Web.Contents(
				        WebconnectorLink,
				        [
				            Query = [ token = connectorkey ]
				        ]
				    ),
				
				    Csv = Csv.Document(Source, [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
				    Out = Table.PromoteHeaders(Csv, [PromoteAllScalars = true])
				in
				    Out

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

