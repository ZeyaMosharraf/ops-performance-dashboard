	measure 'Project By Billabel Hour' = ```
			
			VAR _Page = [# Pages Value]
			VAR _Items = [# Items Value]
			VAR _Item_Rank = [Rank Project Billabel Hour]
			VAR _Filter =
			FILTER(ALLSELECTED(dim_project[Project Name]),
			        _Item_Rank > (_Page - 1) * _Items
			        && _Item_Rank <= (_Page) * _Items
			)
			VAR _itemshow = 
			IF( SELECTEDVALUE(dim_project[Project Name]) IN _Filter, 1,0)
			RETURN
			_itemshow
			```
