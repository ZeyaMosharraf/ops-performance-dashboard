	measure 'Budget Status' =
			
			VAR _budgetedHours = [Budget Hours]
			
			VAR _actualBillableHours = [Total Billable Hours]
			
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(_budgetedHours), BLANK(),
			        _actualBillableHours > _budgetedHours, "Over-Budget",
			        _actualBillableHours < _budgetedHours, "Under-Budget",
			        _actualBillableHours = _budgetedHours, "On-Track"
			    )
		displayFolder: # Category
		lineageTag: 32b786b6-c412-4574-9fe8-a3573912cad5

