	measure 'Utilization Color' = ```
			
			VAR Util = [Utilization Billable %] * 100
			RETURN
			    SWITCH(
			        TRUE(),
			        ISBLANK(Util), "#BFBFBF",             
			        Util < 50, "#FF5C5C",                 -- 🔴 Red
			        Util >= 50 && Util < 70, "#FFD966",   -- 🟡 Yellow
			        Util >= 70, "#92D050",                -- 🟢 Green
			        "#FFFFFF"                             
			    )
