			    DATE(YEAR(SelectedDate), MONTH(SelectedDate) - 1, 1)
			VAR LastDayPrevMonth =
			    EOMONTH(SelectedDate, -1)
			RETURN
			    CALCULATE(
			        [Available Capacity],
			        FILTER(
			            ALL('dim_date'),
			            'dim_date'[Date] >= FirstDayPrevMonth &&
			            'dim_date'[Date] <= LastDayPrevMonth
			        )
			    )
		formatString: 0
		lineageTag: 13df750d-dc9f-47f8-b34f-016602e08859

	measure 'MoM Available Capacity (%)' =
			
			VAR _CurrentMonth = [CM Available Capacity]
			VAR _PreviousMonth = [PM Available Capacity]
			RETURN
			IF(
			    NOT ISBLANK(_PreviousMonth),
			    DIVIDE(_CurrentMonth - _PreviousMonth, _PreviousMonth)
			)
		lineageTag: bf6a6788-f6f3-4d4f-9a31-4bbbb304b81f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Available Capacity % MoM Arrow Label' =
			
			VAR ArrowUp = UNICHAR(9650)
			VAR ArrowDown = UNICHAR(9660)
			VAR Change = [MoM Available Capacity (%)]
			RETURN
			IF(Change > 0,
			     FORMAT(Change, "0.00%") & " " & ArrowUp,
			     FORMAT(Change, "0.00%") & " " & ArrowDown
			)
		lineageTag: cb71df07-9eb3-42cb-bafe-f215b105ed53

	measure 'MOM Available Capacity % Color' =
			
			IF([MoM Available Capacity (%)] >= 0, "Green", "Red")
		lineageTag: 6a68aca0-0731-49da-a90a-90a3cc04b595

