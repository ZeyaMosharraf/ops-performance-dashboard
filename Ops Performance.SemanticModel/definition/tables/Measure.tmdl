	measure 'Budget Hours' =
			
			VAR RetainerHourly =
			    CALCULATE(SUMX (
			        SUMMARIZE (
			            FILTER (
			                ADDCOLUMNS (
			                    fact_ActivityLog,
			                    "PaymentType", RELATED ( dim_project[Payment Type]),
			                    "churndate", RELATED ( dim_project[Churn Date]),
			                    "startdate", RELATED(dim_date[Date])
			                ),
			                [PaymentType] IN { "Retainer" } &&
			                (
			                            ISBLANK([ChurnDate])
			                            || [startdate] <= [ChurnDate]
			                        )
			            ),
			            dim_project[Project Id],
			            dim_date[YearMonth],
			            "MonthlyBudget", MAX ( dim_project[Budget Hours] )
			        ),
			        [MonthlyBudget]
			    ), REMOVEFILTERS(dim_users))
			
			VAR Fixed =
			    CALCULATE(SUMX (
			        SUMMARIZE (
			            FILTER (
			                ADDCOLUMNS (
			                    fact_ActivityLog,
			                    "PaymentType", RELATED ( dim_project[Payment Type] )
			                ),
			                [PaymentType] IN { "Fixed", "Hourly" }
			            ),
			            dim_project[Project Id],
			            "ProjectBudget", MAX ( dim_project[Budget Hours] )
			        ),
			        [ProjectBudget]
			    ), REMOVEFILTERS(dim_users))
			
			RETURN
			RetainerHourly + Fixed
		formatString: #,0
		displayFolder: # Grand Totals
		lineageTag: f34015bf-8bd8-4ceb-8a9c-7a4c5b33be3e

