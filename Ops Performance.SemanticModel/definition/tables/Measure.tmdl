	measure 'PM Non Billable Hours' =
			
			VAR SelectedDate =
			    MAX('dim_date'[Date])
			VAR FirstDayPrevMonth =
			    DATE(YEAR(SelectedDate), MONTH(SelectedDate) - 1, 1)
			VAR LastDayPrevMonth =
			    EOMONTH(SelectedDate, -1)
			RETURN
			    CALCULATE(
			        [Total Non Billable Hours],
			        FILTER(
			            ALL('dim_date'),
			            'dim_date'[Date] >= FirstDayPrevMonth &&
			            'dim_date'[Date] <= LastDayPrevMonth
			        )
			    )
		displayFolder: # Previous Month
		lineageTag: 5c1b42c8-fbf7-4dbc-9c46-5244d7bd6942

		annotation PBI_FormatHint = {"isGeneralNumber":true}

