table EndDate
	isHidden
	lineageTag: 1a5e68ff-57d5-4ef1-9678-b04f3cc6f7ac

	column EndDate
		dataType: dateTime
		isHidden
		formatString: Long Date
		lineageTag: ee352c78-6064-4e02-9ca4-c8881de10a60
		summarizeBy: none
		sourceColumn: EndDate

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition EndDate = m
		mode: import
		queryGroup: Auth
		source =
				let
				    Today = DateTime.Date(DateTime.LocalNow()),
				    Yesterday = Date.AddDays(Today, -1)
